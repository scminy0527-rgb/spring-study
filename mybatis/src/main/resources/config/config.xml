<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0/EN" "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>

    <settings>
        <setting name="jdbcTypeForNull" value="NULL" />
    </settings>

    <typeAliases>
        <!--VO alias 붙이기-->
        <typeAlias type="com.app.mybatis.domain.vo.MemberVO" alias="MemberVO"/>
        <typeAlias type="com.app.mybatis.domain.vo.PostVO" alias="PostVO"/>
        <typeAlias type="com.app.mybatis.domain.vo.PostLikeVO" alias="PostLikeVO"/>

        <!--DTO alias-->
        <typeAlias type="com.app.mybatis.domain.dto.PostDTO" alias="PostDTO"/>
        <typeAlias type="com.app.mybatis.domain.dto.PostCountDTO" alias="PostCountDTO"/>
        <typeAlias type="com.app.mybatis.domain.dto.PostResponseDTO" alias="PostResponse"/>
    </typeAliases>
</configuration>