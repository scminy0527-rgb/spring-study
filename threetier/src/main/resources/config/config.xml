<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0/EN" "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>

    <settings>
        <setting name="jdbcTypeForNull" value="NULL" />
    </settings>

    <typeAliases>
        <!--VO alias 붙이기-->
        <typeAlias type="com.app.threetier.domain.vo.MemberVO" alias="MemberVO"/>
        <typeAlias type="com.app.threetier.domain.vo.PostVO" alias="PostVO"/>
        <typeAlias type="com.app.threetier.domain.vo.ProductVO" alias="ProductVO"/>
        <typeAlias type="com.app.threetier.domain.vo.WorkVO" alias="WorkVO"/>
        <typeAlias type="com.app.threetier.domain.vo.StudentVO" alias="StudentVO"/>
        <typeAlias type="com.app.threetier.domain.vo.CompanyVO" alias="CompanyVO"/>

        <!--DTO alias-->
        <typeAlias type="com.app.threetier.domain.dto.PostDTO" alias="PostDTO"/>
        <typeAlias type="com.app.threetier.domain.dto.StudentDTO" alias="StudentDTO"/>
    </typeAliases>
</configuration>