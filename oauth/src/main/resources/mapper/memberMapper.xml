    <insert id="insert" parameterType="MemberVO">
        INSERT INTO TBL_MEMBER
        <selectKey keyProperty="id" resultType="Long" order="BEFORE">
            SELECT SEQ_MEMBER.NEXTVAL FROM DUAL
        </selectKey>
        VALUES (#{id}, #{memberEmail}, #{memberPassword}, #{memberPicture}, #{memberName}, #{memberNickname})
    </insert>

    <select id="select" parameterType="Long" resultType="MemberDTO">
        SELECT TBM.ID, TBM.MEMBER_EMAIL, TBM.MEMBER_PASSWORD, TBM.MEMBER_PICTURE, TBM.MEMBER_NAME, TBM.MEMBER_NICKNAME,
               TBSM.MEMBER_ID, TBSM.SOCIAL_MEMBER_PROVIDER, TBSM.SOCIAL_MEMBER_PROVIDER_ID
        FROM TBL_MEMBER TBM
         JOIN TBL_SOCIAL_MEMBER TBSM
              ON TBM.ID = TBSM.MEMBER_ID
        WHERE TBM.ID = #{id}
    </select>

