    <select id="existMemberByMemberEmail" parameterType="String" resultType="_Boolean">
        SELECT
            CASE
                WHEN COUNT(ID) > 0
                THEN 1
                ELSE 0
            END
        FROM TBL_MEMBER
        WHERE MEMBER_EMAIL = #{memberEmail}
    </select>

    <select id="selectByMemberEmail" parameterType="String" resultType="MemberDTO">
        SELECT TBM.ID, TBM.MEMBER_EMAIL, TBM.MEMBER_PASSWORD, TBM.MEMBER_PICTURE, TBM.MEMBER_NAME, TBM.MEMBER_NICKNAME,
               TBSM.MEMBER_ID, TBSM.SOCIAL_MEMBER_PROVIDER, TBSM.SOCIAL_MEMBER_PROVIDER_ID
        FROM TBL_MEMBER TBM
        JOIN TBL_SOCIAL_MEMBER TBSM
             ON TBM.ID = TBSM.MEMBER_ID
        WHERE MEMBER_EMAIL = #{memberEmail}
    </select>

