<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.oauth.mapper.SocialMemberMapper">
    <insert id="insert" parameterType="SocialMemberVO">
        <selectKey resultType="Long" keyProperty="id" order="BEFORE">
            SELECT SEQ_SOCIAL_MEMBER.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO TBL_SOCIAL_MEMBER
        VALUES(#{id}, #{socialMemberProviderId}, #{socialMemberProvider}, #{memberId})
    </insert>
</mapper>