<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.restful.mapper.PostMapper">
    <select id="selectAll" resultType="PostDTO" parameterType="Map">
        SELECT
            TBP.ID, TBP.POST_TITLE, TBP.POST_CONTENT, TBP.MEMBER_ID, TBP.POST_READ_COUNT,
            TBM.MEMBER_NAME, TBM.MEMBER_EMAIL
        FROM TBL_POST TBP
                 JOIN TBL_MEMBER TBM ON TBP.MEMBER_ID = TBM.ID
        <choose>
            <when test="order.equals('oldest')">
                ORDER BY TBP.ID ASC
            </when>
            <otherwise>
                ORDER BY TBP.ID DESC
            </otherwise>
        </choose>
    </select>

    <select id="select" parameterType="Long" resultType="PostDTO">
        SELECT
            TBP.ID, TBP.POST_TITLE, TBP.POST_CONTENT, TBP.MEMBER_ID, TBP.POST_READ_COUNT,
            TBM.MEMBER_NAME, TBM.MEMBER_EMAIL
        FROM TBL_POST TBP
                 JOIN TBL_MEMBER TBM ON TBP.MEMBER_ID = TBM.ID
        WHERE TBP.ID = #{id}
    </select>

    <insert id="insert" parameterType="PostVO">
        <selectKey resultType="Long" keyProperty="id" order="BEFORE">
            SELECT SEQ_POST.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO TBL_POST (ID, POST_TITLE, POST_CONTENT, MEMBER_ID)
        VALUES (#{id}, #{postTitle}, #{postContent}, #{memberId})
    </insert>

    <update id="update" parameterType="PostVO">
        UPDATE TBL_POST
        <set>
            <if test="postTitle != null and postTitle != ''">
                ,POST_TITLE = #{postTitle}
            </if>
            <if test="postContent != null and postContent != ''">
                ,POST_CONTENT = #{postContent}
            </if>
        </set>
        WHERE ID = #{id}
    </update>

    <delete id="delete" parameterType="Long">
        DELETE FROM TBL_POST
        WHERE ID = #{id}
    </delete>

    <delete id="deleteByMemberId" parameterType="Long">
        DELETE FROM TBL_POST
        WHERE MEMBER_ID = #{memberId}
    </delete>

</mapper>